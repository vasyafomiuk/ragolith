{
  "name": "ragolith",
  "version": "0.1.0",
  "description": "RAG pipeline that indexes git repositories and documents into Weaviate, then exposes semantic search to LLM clients via MCP (Model Context Protocol) over stdio.",
  "type": "module",
  "license": "MIT",
  "author": {
    "name": "Vasyl Fomiuk",
    "url": "https://github.com/vasyafomiuk"
  },
  "homepage": "https://github.com/vasyafomiuk/ragolith#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vasyafomiuk/ragolith.git"
  },
  "bugs": {
    "url": "https://github.com/vasyafomiuk/ragolith/issues"
  },
  "keywords": [
    "rag",
    "mcp",
    "model-context-protocol",
    "weaviate",
    "semantic-search",
    "code-search",
    "vector-database",
    "embeddings",
    "llm",
    "claude",
    "ast",
    "typescript"
  ],
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.js.map",
    "dist/dashboard/public/**",
    "docker-compose.yml",
    "docker-compose.integration.yml",
    "ragc.config.example.json",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "bin": {
    "ragolith-server": "./dist/mcp/server.js",
    "ragolith-ingest": "./dist/cli/ingest.js",
    "ragolith-backup": "./dist/cli/backup.js",
    "ragolith-dashboard": "./dist/dashboard/server.js",
    "ragolith-init": "./dist/cli/init.js",
    "ragolith-doctor": "./dist/cli/doctor.js",
    "ragolith-eval": "./dist/cli/eval.js",
    "ragolith-analyze": "./dist/cli/analyze.js"
  },
  "exports": {
    ".": "./dist/core/index.js",
    "./mcp/server": "./dist/mcp/server.js",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-dashboard-assets.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run all",
    "all": "npm run check:layers && npm run lint && npm run format:check && npm run typecheck && npm run build && npm run coverage",
    "test": "node scripts/test.mjs",
    "test:watch": "node scripts/test.mjs --watch",
    "test:integration": "node scripts/test.mjs --integration",
    "test:all": "node scripts/test.mjs --all",
    "coverage": "c8 node scripts/test.mjs",
    "coverage:open": "c8 node scripts/test.mjs && open coverage/index.html",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check:layers": "node scripts/check-layers.mjs",
    "server": "tsx src/mcp/server.ts",
    "ingest": "tsx src/cli/ingest.ts",
    "backup": "tsx src/cli/backup.ts",
    "dashboard": "tsx src/dashboard/server.ts",
    "init": "tsx src/cli/init.ts",
    "doctor": "tsx src/cli/doctor.ts",
    "eval": "tsx src/cli/eval.ts",
    "analyze": "tsx src/cli/analyze.ts",
    "weaviate:up": "docker compose up -d",
    "weaviate:down": "docker compose down",
    "weaviate:logs": "docker compose logs -f weaviate"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "commander": "^12.1.0",
    "ignore": "^5.3.2",
    "mammoth": "^1.8.0",
    "pdfjs-dist": "^5.7.284",
    "simple-git": "^3.27.0",
    "tree-sitter-wasms": "0.1.13",
    "typescript": "^5.6.3",
    "weaviate-client": "~3.12.1",
    "web-tree-sitter": "0.22.6",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "9.32.0",
    "@types/node": "^20.17.10",
    "c8": "10.1.3",
    "eslint": "9.32.0",
    "eslint-config-prettier": "9.1.0",
    "prettier": "3.4.2",
    "tsx": "^4.19.2",
    "typescript-eslint": "8.40.0"
  }
}
