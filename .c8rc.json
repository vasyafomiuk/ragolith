{
  "_comment": "c8 coverage config. Thresholds are strict — CI fails if any drops below. Excludes are files that are integration-only (need Weaviate/git/binaries) or are pure type declarations with no executable code.",
  "all": true,
  "include": ["src/**/*.ts"],
  "exclude": [
    "src/**/*.d.ts",
    "src/**/index.ts",
    "src/core/types.ts",
    "src/cli/**",
    "src/mcp/**",
    "src/dashboard/**",
    "src/core/weaviate-client.ts",
    "src/core/git-manager.ts"
  ],
  "exclude-after-remap": true,
  "reporter": ["text", "text-summary", "html", "lcov", "json-summary"],
  "reports-dir": "coverage",
  "lines": 86,
  "functions": 95,
  "branches": 79,
  "statements": 86,
  "check-coverage": true,
  "skip-full": false
}
