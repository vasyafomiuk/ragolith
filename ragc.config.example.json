{
  "weaviate": {
    "host": "localhost",
    "httpPort": 8080,
    "grpcPort": 50051,
    "secure": false
  },
  "ingest": {
    "workDir": ".ragolith/repos",
    "stateFile": ".ragolith/data.json",
    "extensions": [
      ".ts",
      ".tsx",
      ".js",
      ".jsx",
      ".mjs",
      ".cjs",
      ".java",
      ".cs",
      ".sql",
      ".py",
      ".go",
      ".rs",
      ".rb",
      ".php",
      ".xaml",
      ".razor",
      ".cshtml",
      ".md",
      ".mdx",
      ".txt",
      ".pdf",
      ".docx"
    ],
    "maxFileBytes": 1048576
  },
  "search": {
    "overFetch": 2,
    "diversityPerFile": 3,
    "rerankerEnabled": true
  },
  "repos": [
    {
      "name": "example-repo",
      "repo": "https://github.com/example/repo.git",
      "branch": "main",
      "subPaths": ["src", "docs"]
    }
  ],
  "documents": [
    {
      "name": "spec-pdf",
      "path": "/absolute/path/to/spec.pdf"
    }
  ],
  "sdlc": [
    {
      "name": "product-requirements",
      "path": "/absolute/path/to/sdlc",
      "source": "local",
      "project": "example-repo"
    }
  ],
  "backup": {
    "backend": "filesystem",
    "s3": {
      "bucket": "",
      "region": "us-east-1",
      "prefix": "ragolith/"
    }
  }
}
